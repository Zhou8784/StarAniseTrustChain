<view class="page">
  <view class="page-title">历史检测记录</view>

  <!-- 空状态 -->
  <view wx:if="{{reportList.length === 0}}" class="empty-text">
    暂无上链记录
  </view>

  <!-- 上链记录列表 -->
  <view
    wx:for="{{reportList}}"
    wx:key="id"
    class="history-card"
    data-item="{{item}}"
    bindtap="goDetail"
  >
    <view class="top">
      <text class="level">{{item.level}}</text>
      <view class="status-tag tag-success">✅ 已上链</view>
    </view>

    <view class="info">
      <text>批次号：{{item.batchNumber}}</text>
    </view>

    <view class="info">
      <text>检测时间：{{item.detectTime}}</text>
    </view>

    <view class="bottom">
      <text>正常果率 {{item.goodRate}}</text>
      <text class="more">查看报告 ></text>
    </view>
  </view>
</view>