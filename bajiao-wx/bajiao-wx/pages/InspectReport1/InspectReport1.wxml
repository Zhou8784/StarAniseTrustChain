<scroll-view scroll-y="true" class="page">

<!-- 顶部报告 -->
<view class="header">
  <text class="title">八角品质检测报告</text>
  <text class="batch">批次号：{{batchNumber}}</text>
  <text class="time">检测时间：{{reportTime}}</text>
</view>

<!-- 综合检测结果 -->
<view class="summary-card">
  <view class="summary-top">
    <view class="level-box">
      <text class="level-label">综合品质等级</text>
      <text class="level">{{detectionResult.grade}}</text>
    </view>
    <view class="chain-tag">✅ 已上链</view>
  </view>

  <view class="summary-grid">
    <view class="summary-item">
      <text class="summary-value">{{detectionResult.goodRate}}</text>
      <text class="summary-name">正常果率</text>
    </view>
    <view class="summary-item">
      <text class="summary-value">{{detectionResult.brokenRate}}</text>
      <text class="summary-name">破碎率</text>
    </view>
    <view class="summary-item">
      <text class="summary-value">{{detectionResult.impurityRate}}</text>
      <text class="summary-name">杂质率</text>
    </view>
    <view class="summary-item">
      <text class="summary-value">{{detectionResult.moldRate}}</text>
      <text class="summary-name">霉变率</text>
    </view>
  </view>
</view>

<!-- AI检测结果图 -->
<view class="card" style="overflow: visible;">
  <view class="card-title">AI检测结果图</view>
  <view wx:if="{{detectionResult.imagePath}}" class="image-wrapper">
    <image 
      class="detect-image" 
      src="{{detectionResult.imagePath}}" 
      mode="widthFix"
      binderror="onImageError"
      bindload="onImageLoad"
      show-menu-by-longpress="{{true}}"
    />
  </view>
  <view wx:else class="image-empty">暂无检测图片</view>
</view>

<!-- AI识别统计 -->
<view class="card">
  <view class="card-title">AI识别统计</view>
  <view class="statistics-grid">
    <view class="statistics-item">
      <text class="statistics-number">{{detectionResult.totalCount}}</text>
      <text class="statistics-name">检测总数</text>
    </view>
    <view class="statistics-item">
      <text class="statistics-number">{{detectionResult.goodCount}}</text>
      <text class="statistics-name">正常果</text>
    </view>
    <view class="statistics-item">
      <text class="statistics-number">{{detectionResult.brokenCount}}</text>
      <text class="statistics-name">破碎果</text>
    </view>
    <view class="statistics-item">
      <text class="statistics-number">{{detectionResult.impurityCount}}</text>
      <text class="statistics-name">杂质</text>
    </view>
    <view class="statistics-item">
      <text class="statistics-number">{{detectionResult.moldCount}}</text>
      <text class="statistics-name">霉变</text>
    </view>
  </view>
</view>

<!-- 产品溯源信息 -->
<view class="card">
  <view class="card-title">产品溯源信息</view>
  <view class="row">
    <text>产地</text>
    <text>{{detectionResult.origin}}</text>
  </view>
  <view class="row">
    <text>检测地点</text>
    <text>{{detectionResult.detectLocation}}</text>
  </view>
  <view class="row">
    <text>检测时间</text>
    <text>{{reportTime}}</text>
  </view>
  <view class="row">
    <text>检测批次</text>
    <text>{{batchNumber}}</text>
  </view>
</view>

<!-- 检测设备信息 -->
<view class="card">
  <view class="card-title">检测设备信息</view>
  <view class="row">
    <text>边缘计算平台</text>
    <text>{{detectionResult.device}}</text>
  </view>
  <view class="row">
    <text>AI检测模型</text>
    <text>{{detectionResult.model}}</text>
  </view>
  <view class="row">
    <text>图像采集设备</text>
    <text>{{detectionResult.camera}}</text>
  </view>
</view>

<!-- 区块链存证信息 -->
<view class="card">
  <view class="card-title">区块链存证信息</view>
  <view class="row">
    <text>存证状态</text>
    <view class="status-tag {{detectionResult.blockchainStatus === '已上链' ? 'tag-success' : 'tag-pending'}}">
      {{detectionResult.blockchainStatus || '未上链'}}
    </view>
  </view>
  <view class="hash-card">
    <text class="hash-title">Transaction Hash</text>
    <text class="hash-content">{{detectionResult.txHash || '待生成'}}</text>
  </view>
</view>

<!-- 溯源码和二维码 -->
<view class="card" style="overflow: visible;">
  <view class="card-title">产品溯源码</view>
  <view class="trace-code-box">
    <text class="trace-code">{{detectionResult.traceCode || '暂未生成'}}</text>
  </view>
  <view wx:if="{{detectionResult.qrcode}}" class="qrcode-wrapper" bindtap="previewQRCode">
    <image 
      class="qrcode-img" 
      src="{{detectionResult.qrcode}}" 
      mode="widthFix"
      binderror="onImageError"
      bindload="onImageLoad"
      show-menu-by-longpress="{{true}}"
    />
    <text class="qrcode-tip">点击二维码可放大查看</text>
  </view>
  <view wx:else class="qrcode-empty">
    <text>暂未生成二维码</text>
  </view>
</view>

<view style="height:40rpx;"></view>

</scroll-view>